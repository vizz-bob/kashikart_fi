# ═══════════════════════════════════════════════════════════════
#  KashiKart Tender Intelligence — Environment Variables Template
#  Copy this file to .env and fill in all values before deploying
# ═══════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────
APP_NAME=KashiKart
APP_VERSION=1.0.0
ENVIRONMENT=production          # development | staging | production

# ── Database (AWS RDS PostgreSQL) ───────────────────────────────
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://kashikart_user:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/kashikart_db
DATABASE_PASSWORD=YOUR_DB_PASSWORD

# ── Security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_32_byte_hex_string
ENCRYPTION_KEY=CHANGE_ME_generate_another_32_byte_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AWS S3 ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=kashikart-tender-data

# ── SMTP (Email Notifications) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=YOUR_GMAIL_ADDRESS@gmail.com
SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
SMTP_FROM_EMAIL=YOUR_GMAIL_ADDRESS@gmail.com

# ── URLs ────────────────────────────────────────────────────────
# Use EC2 public IP (no domain)
FRONTEND_URL=http://13.232.38.191
BACKEND_URL=http://13.232.38.191:8000

# ── Upload directories (EC2 paths) ───────────────────────────────
UPLOAD_DIR=/home/ubuntu/kashikart/uploads
BRANDING_UPLOAD_DIR=/home/ubuntu/kashikart/branding
